import pandas as pd
import glob

files = glob.glob("/data/input/*.csv")

header_saved = False

with open("/data/output/final.csv", "w", newline="") as out_file:

    for file in files:
        df = pd.read_csv(file)

        df.to_csv(
            out_file,
            index=False,
            header=not header_saved
        )

        header_saved = True
